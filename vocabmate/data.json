l":1,"lapses":1,"nextDate":"2026-07-08","reps":1},"sentence":"Chunked prefill is a technique for handling long prompts by splitting their prefill step into smaller chunks. Without it, we could end up with a single very long request monopolizing one engine step disallowing other prefill requests to run. That would postpone all other requests and increase their latency.","sourceTitle":"Inside vLLM: Anatomy of a High-Throughput LLM Inference System | vLLM Blog","sourceUrl":"https://vllm.ai/blog/2025-09-05-anatomy-of-vllm#llm-engine--engine-core","word":"disallowing"},"postpone":{"addedAt":1783151548135,"addedDate":"2026-07-04","audioUk":"","audioUs":"https://api.dictionaryapi.dev/media/pronunciations/en/postpone-us.mp3","baseForms":["postpone"],"definition":"//poʊstˈpoʊn//\nverb\n  1. To delay or put off an event, appointment etc.","definitions":[{"example":"","meanings":["To delay or put off an event, appointment etc."],"partOfSpeech":"verb"}],"note":"","phonetic":"/poʊstˈpoʊn/","review":{"easeFactor":1.3800000000000001,"interval":1,"lapses":2,"nextDate":"2026-07-08","reps":0},"sentence":"Chunked prefill is a technique for handling long prompts by splitting their prefill step into smaller chunks. Without it, we could end up with a single very long request monopolizing one engine step disallowing other prefill requests to run. That would postpone all other requests and increase their latency.","sourceTitle":"Inside vLLM: Anatomy of a High-Throughput LLM Inference System | vLLM Blog","sourceUrl":"https://vllm.ai/blog/2025-09-05-anatomy-of-vllm#llm-engine--engine-core","word":"postpone"}},"_meta":{"exportedAt":"2026-07-06T16:17:58.605Z","version":2,"source":"vocabmate"}}